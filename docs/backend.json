{
  "entities": {
    "Assignment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Assignment",
      "type": "object",
      "description": "Represents a student's submitted assignment file and its extracted text content.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Assignment entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who uploaded this assignment."
        },
        "title": {
          "type": "string",
          "description": "The title or name given to the assignment."
        },
        "fileName": {
          "type": "string",
          "description": "The original file name of the uploaded assignment."
        },
        "fileType": {
          "type": "string",
          "description": "The MIME type of the uploaded assignment."
        },
        "fileUrl": {
          "type": "string",
          "description": "The Cloudinary URL where the raw file is stored."
        },
        "content": {
          "type": "string",
          "description": "The extracted text content from the assignment file."
        },
        "uploadDateTime": {
          "type": "string",
          "description": "The date and time when the assignment was uploaded.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "title",
        "fileName",
        "fileType",
        "content",
        "uploadDateTime"
      ]
    },
    "Rubric": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Rubric",
      "type": "object",
      "description": "Represents an evaluation rubric.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Rubric entity."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who created or uploaded this rubric."
        },
        "name": {
          "type": "string",
          "description": "A descriptive name for the rubric."
        },
        "originalContent": {
          "type": "string",
          "description": "The raw text of the rubric."
        },
        "structuredContent": {
          "type": "string",
          "description": "The JSON string representation of the parsed rubric criteria."
        },
        "uploadDateTime": {
          "type": "string",
          "description": "The date and time when the rubric was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "name",
        "originalContent",
        "structuredContent",
        "uploadDateTime"
      ]
    },
    "Evaluation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Evaluation",
      "type": "object",
      "description": "Represents a single evaluation instance.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Evaluation entity."
        },
        "assignmentId": {
          "type": "string",
          "description": "Reference to the Assignment that was evaluated."
        },
        "rubricId": {
          "type": "string",
          "description": "Reference to the Rubric used for this evaluation."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who initiated this evaluation."
        },
        "fileUrl": {
          "type": "string",
          "description": "Direct Cloudinary URL to the original file for reference."
        },
        "evaluationDateTime": {
          "type": "string",
          "description": "The date and time when the evaluation was performed.",
          "format": "date-time"
        },
        "overallSummary": {
          "type": "string",
          "description": "A summary generated by the LLM."
        },
        "integrityFlag": {
          "type": "string",
          "description": "Originality risk level."
        },
        "confidenceScore": {
          "type": "number",
          "description": "LLM confidence score."
        },
        "selectedLanguage": {
          "type": "string",
          "description": "Target language for feedback."
        }
      },
      "required": [
        "id",
        "assignmentId",
        "rubricId",
        "userId",
        "evaluationDateTime",
        "overallSummary",
        "integrityFlag",
        "confidenceScore",
        "selectedLanguage"
      ]
    },
    "CriterionEvaluation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CriterionEvaluation",
      "type": "object",
      "description": "Represents the detailed results for a single criterion.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier."
        },
        "evaluationId": {
          "type": "string",
          "description": "Parent evaluation ID."
        },
        "criterionName": {
          "type": "string",
          "description": "Name of the criterion."
        },
        "maxMarks": {
          "type": "number",
          "description": "Maximum marks possible."
        },
        "score": {
          "type": "number",
          "description": "Awarded score."
        },
        "feedback": {
          "type": "string",
          "description": "LLM feedback."
        },
        "suggestions": {
          "type": "string",
          "description": "LLM suggestions."
        },
        "order": {
          "type": "number",
          "description": "Display order."
        }
      },
      "required": [
        "id",
        "evaluationId",
        "criterionName",
        "maxMarks",
        "score",
        "feedback",
        "suggestions",
        "order"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/assignments/{assignmentId}",
        "definition": {
          "entityName": "Assignment",
          "schema": {
            "$ref": "#/backend/entities/Assignment"
          },
          "description": "Stores assignments with Cloudinary file links."
        }
      },
      {
        "path": "/users/{userId}/rubrics/{rubricId}",
        "definition": {
          "entityName": "Rubric",
          "schema": {
            "$ref": "#/backend/entities/Rubric"
          },
          "description": "Stores user rubrics."
        }
      },
      {
        "path": "/users/{userId}/evaluations/{evaluationId}",
        "definition": {
          "entityName": "Evaluation",
          "schema": {
            "$ref": "#/backend/entities/Evaluation"
          },
          "description": "Stores evaluation summaries including source document URLs."
        }
      },
      {
        "path": "/users/{userId}/evaluations/{evaluationId}/criterionEvaluations/{criterionEvaluationId}",
        "definition": {
          "entityName": "CriterionEvaluation",
          "schema": {
            "$ref": "#/backend/entities/CriterionEvaluation"
          },
          "description": "Stores detailed criteria results."
        }
      }
    ],
    "reasoning": "Organizational structure follows a user-centric hierarchy with path-based ownership. Cloudinary URLs are denormalized into the Assignment and Evaluation documents for immediate accessibility without additional lookups."
  }
}
